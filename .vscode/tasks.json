{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Current TeX File",
      "type": "shell",
      "command": "pdflatex",
      "args": [
        "-interaction=nonstopmode",
        "${file}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}